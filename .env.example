# ── Required: LLM (OpenRouter) ────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Any OpenRouter model slug. See https://openrouter.ai/models
# Cheap/fast picks that handle JSON well:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-haiku
#   google/gemini-2.0-flash-001
#   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Slack delivery — pick ONE path ─────────────────
# Path A (EASIEST): an incoming webhook posts to a fixed channel.
# Create at: your-workspace.slack.com → Apps → "Incoming Webhooks"
SLACK_WEBHOOK_URL=

# Path B (FULL BOT): for slash commands or posting to multiple channels.
# api.slack.com/apps → Create app → OAuth scopes: chat:write → install
SLACK_BOT_TOKEN=
SLACK_CHANNEL=discovery-feed

# ── Optional: Behaviour ───────────────────────────
PICKS_PER_DIGEST=5
DAILY_POST_TIME=09:00
DIGEST_TITLE=🔭 Discovery Feed

# ── Optional: Sources ─────────────────────────────
ENABLE_HN=true
ENABLE_PH=true
ENABLE_GITHUB=true

# Product Hunt needs an API key (free at producthunt.com/v2/oauth/applications)
PRODUCTHUNT_API_KEY=

# Comma-separated; empty = all languages. Example: python,typescript,rust
GITHUB_LANGUAGES=

# ── Optional: State file ──────────────────────────
STATE_FILE=data/seen.json
